# Generic template.
# Copy this file to .env or another local .env.* file and replace placeholders.

# Server Port Spring Boot
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# URLs for frontend
APP_FRONTEND_URL=http://localhost:4200
APP_LOGOUT_REDIRECT=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Database Connection - Supabase Session Pooler (IPv4)
DB_HOST=aws-1-your-region.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_ADMIN_USER=postgres.your-project-ref
DB_ADMIN_PASSWORD=your-admin-password
DB_APP_ROLE=redsun_dev
DB_USER=redsun_dev.your-project-ref
DB_PASSWORD=your-runtime-password
# Optional admin/reset SQL endpoint override. Defaults to DB_HOST/DB_PORT.
# For Supabase free-tier IPv4 Session Pooler, leave these unset.
# DB_ADMIN_HOST=your-direct-db-host
# DB_ADMIN_PORT=5432

# REST or Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public/
SUPABASE_SECRET_KEY=your-supabase-secret-key
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# Brevo
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-sender-email
BREVO_SENDER_NAME=RedSun_Dev

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
