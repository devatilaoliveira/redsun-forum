{
  "name": "redsun-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build",
    "build:local": "ng build --configuration local-production",
    "start:local": "ng serve --configuration local-production --port 4200",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "fix": "ng lint --fix",
    "rsAgents": "powershell -ExecutionPolicy Bypass -File ../../scripts/rsAgents.ps1 -App web",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@supabase/supabase-js": "^2.80.0",
    "ngx-image-cropper": "^9.1.6",
    "rxjs": "~7.8.0",
    "swiper": "12.1.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.6",
    "@angular/cli": "^20.3.6",
    "@angular/compiler-cli": "^20.3.0",
     "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.5.0",
    "angular-eslint": "20.6.0",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.39.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.3"
  }
}
