{
  "name": "redsun-web",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "ng": "ng",
    "prebuild": "node scripts/write-env.js",
    "build": "ng build",
    "start:prod": "ng serve --configuration prod --port 4200",
    "start:stage": "ng serve --configuration stage --port 4200",
    "start:local-prod": "ng serve --configuration local-prod --port 4200",
    "lint": "ng lint",
    "fix": "ng lint --fix",
    "codexLaucher": "powershell -ExecutionPolicy Bypass -File ../../scripts/codexLaucher.ps1 -App web",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@supabase/supabase-js": "^2.80.0",
    "ngx-image-cropper": "^9.1.6",
    "rxjs": "~7.8.0",
    "swiper": "^12.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.9.4",
    "angular-eslint": "^22.0.0",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.39.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
