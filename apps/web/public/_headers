# Cloudflare Workers Static Assets already serves unmatched files with:
# Cache-Control: public, max-age=0, must-revalidate
# Keep HTML, env.js, and i18n JSON on that default revalidation path.

/main-*.js
  Cache-Control: public, max-age=31536000, immutable

/polyfills-*.js
  Cache-Control: public, max-age=31536000, immutable

/chunk-*.js
  Cache-Control: public, max-age=31536000, immutable

/styles-*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*
  Cache-Control: public, max-age=3600, must-revalidate

/assets/svgs/*
  Cache-Control: public, max-age=3600, must-revalidate

/ico/*
  Cache-Control: public, max-age=3600, must-revalidate
